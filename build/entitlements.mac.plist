<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Electron/Chromium needs a JIT and writable+executable memory for V8. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<!-- Allow loading the app's own (Developer ID signed) native modules/frameworks. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<!-- Some Electron flows rely on DYLD_* env vars (e.g. ELECTRON_RUN_AS_NODE). -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	<!-- Permit sending Apple events (e.g. opening the default browser / Finder). -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
